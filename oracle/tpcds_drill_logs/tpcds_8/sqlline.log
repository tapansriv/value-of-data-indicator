                                     '35576') INTERSECT 
        SELECT ca_zip 
        FROM 
          (SELECT SUBSTRING(customer_address.ca_zip, 1, 5) ca_zip, 
                  count(*) cnt 
           FROM dfs.`tmp/customer_address.parquet` AS customer_address, 
                dfs.`tmp/customer.parquet` AS customer 
           WHERE customer_address.ca_address_sk = customer.c_current_addr_sk 
             AND customer.c_preferred_cust_flag='Y' 
           GROUP BY customer_address.ca_zip 
           HAVING count(*) > 10)A1)A2) V1 
WHERE store_sales.ss_store_sk = store.s_store_sk 
  AND store_sales.ss_sold_date_sk = date_dim.d_date_sk 
  AND date_dim.d_qoy = 2 
  AND date_dim.d_year = 1998 
  AND (SUBSTRING(store.s_zip, 1, 2) = SUBSTRING(V1.ca_zip, 1, 2)) 
GROUP BY store.s_store_name 
ORDER BY store.s_store_name 
LIMIT 100
