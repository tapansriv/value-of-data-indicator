    "query_name": "\nSELECT count(DISTINCT ws_order_number) AS \"order count\" ,\n       sum(ws_ext_ship_cost) AS \"total shipping cost\" ,\n       sum(ws_net_profit) AS \"total net profit\"\nFROM 'web_sales.parquet' ws1 ,\n     'date_dim.parquet' AS date_dim ,\n     'customer_address.parquet' AS customer_address ,\n     'web_site.parquet' AS web_site\nWHERE d_date BETWEEN '1999-02-01' AND cast('1999-04-02' AS date)\n  AND ws1.ws_ship_date_sk = d_date_sk\n  AND ws1.ws_ship_addr_sk = ca_address_sk\n  AND ca_state = 'IL'\n  AND ws1.ws_web_site_sk = web_site_sk\n  AND web_company_name = 'pri'\n  AND EXISTS\n    (SELECT *\n     FROM 'web_sales.parquet' ws2\n     WHERE ws1.ws_order_number = ws2.ws_order_number\n       AND ws1.ws_warehouse_sk <> ws2.ws_warehouse_sk)\n  AND NOT exists\n    (SELECT *\n     FROM 'web_returns.parquet' wr1\n     WHERE ws1.ws_order_number = wr1.wr_order_number)\nORDER BY count(DISTINCT ws_order_number)\nLIMIT 100;\n\n",
