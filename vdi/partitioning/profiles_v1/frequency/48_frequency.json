    "query_name": "SELECT\n  SUM(ss_quantity)\nFROM READ_PARQUET('/home/cc/tpcds_partitioned_freq/store_sales/**/*.parquet', hive_partitioning = 1) AS store_sales, READ_PARQUET('store.parquet') AS store, READ_PARQUET('customer_demographics.parquet') AS customer_demographics, READ_PARQUET('customer_address.parquet') AS customer_address, READ_PARQUET('/home/cc/tpcds_partitioned_freq/date_dim/**/*.parquet', hive_partitioning = 1) AS date_dim\nWHERE\n  s_store_sk = ss_store_sk\n  AND ss_sold_date_sk = d_date_sk\n  AND d_year = 2000\n  AND (\n    (\n      cd_demo_sk = ss_cdemo_sk\n      AND cd_marital_status = 'M'\n      AND cd_education_status = '4 yr Degree'\n      AND ss_sales_price BETWEEN 100.00 AND 150.00\n    )\n    OR (\n      cd_demo_sk = ss_cdemo_sk\n      AND cd_marital_status = 'D'\n      AND cd_education_status = '2 yr Degree'\n      AND ss_sales_price BETWEEN 50.00 AND 100.00\n    )\n    OR (\n      cd_demo_sk = ss_cdemo_sk\n      AND cd_marital_status = 'S'\n      AND cd_education_status = 'College'\n      AND ss_sales_price BETWEEN 150.00 AND 200.00\n    )\n  )\n  AND (\n    (\n      ss_addr_sk = ca_address_sk\n      AND ca_country = 'United States'\n      AND ca_state IN ('CO', 'OH', 'TX')\n      AND ss_net_profit BETWEEN 0 AND 2000\n    )\n    OR (\n      ss_addr_sk = ca_address_sk\n      AND ca_country = 'United States'\n      AND ca_state IN ('OR', 'MN', 'KY')\n      AND ss_net_profit BETWEEN 150 AND 3000\n    )\n    OR (\n      ss_addr_sk = ca_address_sk\n      AND ca_country = 'United States'\n      AND ca_state IN ('VA', 'CA', 'MS')\n      AND ss_net_profit BETWEEN 50 AND 25000\n    )\n  )",
