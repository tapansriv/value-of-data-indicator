    "query_name": "SELECT case when pmc=0 then null else cast(amc AS decimal(15,4))/cast(pmc AS decimal(15,4)) end am_pm_ratio\nFROM\n  (SELECT count(*) amc\n   FROM 'web_sales.parquet' AS web_sales,\n        'household_demographics.parquet' AS household_demographics,\n        'time_dim.parquet' AS time_dim,\n        'web_page.parquet' AS web_page\n   WHERE ws_sold_time_sk = time_dim.t_time_sk\n     AND ws_ship_hdemo_sk = household_demographics.hd_demo_sk\n     AND ws_web_page_sk = web_page.wp_web_page_sk\n     AND time_dim.t_hour BETWEEN 8 AND 8+1\n     AND household_demographics.hd_dep_count = 6\n     AND web_page.wp_char_count BETWEEN 5000 AND 5200) at1,\n  (SELECT count(*) pmc\n   FROM 'web_sales.parquet' AS web_sales,\n        'household_demographics.parquet' AS household_demographics,\n        'time_dim.parquet' AS time_dim,\n        'web_page.parquet' AS web_page\n   WHERE ws_sold_time_sk = time_dim.t_time_sk\n     AND ws_ship_hdemo_sk = household_demographics.hd_demo_sk\n     AND ws_web_page_sk = web_page.wp_web_page_sk\n     AND time_dim.t_hour BETWEEN 19 AND 19+1\n     AND household_demographics.hd_dep_count = 6\n     AND web_page.wp_char_count BETWEEN 5000 AND 5200) pt\nORDER BY am_pm_ratio\nLIMIT 100;\n\n",
