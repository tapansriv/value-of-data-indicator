    "query_name": "SELECT\n  ss_customer_sk,\n  SUM(act_sales) AS sumsales\nFROM (\n    SELECT\n      ss_item_sk,\n      ss_ticket_number,\n      ss_customer_sk,\n      CASE\n        WHEN NOT sr_return_quantity IS NULL\n        THEN (\n          ss_quantity - sr_return_quantity\n        ) * ss_sales_price\n        ELSE (\n          ss_quantity * ss_sales_price\n        )\n      END AS act_sales\n    FROM READ_PARQUET('/home/cc/tpcds_cluster_base/store_sales/*.parquet') AS store_sales\n    LEFT OUTER JOIN READ_PARQUET('/home/cc/tpcds_cluster_base/store_returns/*.parquet') AS store_returns\n      ON (\n        sr_item_sk = ss_item_sk AND sr_ticket_number = ss_ticket_number\n      ), READ_PARQUET('/home/cc/tpcds_cluster_base/reason/*.parquet') AS reason\n    WHERE\n      sr_reason_sk = r_reason_sk AND r_reason_desc = 'reason 28'\n) AS t\nGROUP BY\n  ss_customer_sk\nORDER BY\n  sumsales NULLS FIRST,\n  ss_customer_sk NULLS FIRST\nLIMIT 100",
