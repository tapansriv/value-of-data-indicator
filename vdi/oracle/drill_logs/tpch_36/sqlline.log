	100.00 * sum(case 
		when part.p_type like 'PROMO%' 
			then lineitem.l_extendedprice * (1 - lineitem.l_discount) 
		else 0 
	end) / sum(lineitem.l_extendedprice * (1 - lineitem.l_discount)) as promo_revenue 
