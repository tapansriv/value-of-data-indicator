2025-08-20 18:27:15,710 [1759ec7c-1cbb-9224-d4e9-04dcba88170f:foreman] INFO  o.a.drill.exec.work.foreman.Foreman - Query text for query with id 1759ec7c-1cbb-9224-d4e9-04dcba88170f issued by anonymous: SELECT channel, 
       item, 
       return_ratio, 
       return_rank, 
       currency_rank 
FROM 
  (SELECT 'web' AS channel, 
          web.item, 
          web.return_ratio, 
          web.return_rank, 
          web.currency_rank 
   FROM 
     (SELECT item, 
             return_ratio, 
             currency_ratio, 
             rank() OVER ( 
                          ORDER BY return_ratio) AS return_rank, 
                         rank() OVER ( 
                                      ORDER BY currency_ratio) AS currency_rank 
      FROM 
        (SELECT ws.ws_item_sk AS item, 
                (cast(sum(coalesce(wr.wr_return_quantity,0)) AS decimal(15,4))/ cast(sum(coalesce(ws.ws_quantity,0)) AS decimal(15,4))) AS return_ratio, 
                (cast(sum(coalesce(wr.wr_return_amt,0)) AS decimal(15,4))/ cast(sum(coalesce(ws.ws_net_paid,0)) AS decimal(15,4))) AS currency_ratio 
         FROM dfs.`tmp/web_sales.parquet` ws 
         LEFT OUTER JOIN dfs.`tmp/web_returns.parquet` wr ON (ws.ws_order_number = wr.wr_order_number 
                                            AND ws.ws_item_sk = wr.wr_item_sk) ,dfs.`tmp/date_dim.parquet` AS date_dim 
         WHERE wr.wr_return_amt > 10000 
           AND ws.ws_net_profit > 1 
           AND ws.ws_net_paid > 0 
           AND ws.ws_quantity > 0 
           AND ws.ws_sold_date_sk = date_dim.d_date_sk 
           AND date_dim.d_year = 2001 
           AND date_dim.d_moy = 12 
         GROUP BY ws.ws_item_sk) in_web) web 
   WHERE (web.return_rank <= 10 
          OR web.currency_rank <= 10) 
   UNION SELECT 'catalog' AS channel, 
                catalog.item, 
                catalog.return_ratio, 
                catalog.return_rank, 
                catalog.currency_rank 
   FROM 
     (SELECT item, 
             return_ratio, 
             currency_ratio, 
             rank() OVER ( 
                          ORDER BY return_ratio) AS return_rank, 
                         rank() OVER ( 
                                      ORDER BY currency_ratio) AS currency_rank 
      FROM 
        (SELECT cs.cs_item_sk AS item, 
                (cast(sum(coalesce(cr.cr_return_quantity,0)) AS decimal(15,4))/ cast(sum(coalesce(cs.cs_quantity,0)) AS decimal(15,4))) AS return_ratio, 
                (cast(sum(coalesce(cr.cr_return_amount,0)) AS decimal(15,4))/ cast(sum(coalesce(cs.cs_net_paid,0)) AS decimal(15,4))) AS currency_ratio 
         FROM dfs.`tmp/catalog_sales.parquet` cs 
         LEFT OUTER JOIN dfs.`tmp/catalog_returns.parquet` cr ON (cs.cs_order_number = cr.cr_order_number 
                                                AND cs.cs_item_sk = cr.cr_item_sk) ,dfs.`tmp/date_dim.parquet` AS date_dim 
         WHERE cr.cr_return_amount > 10000 
           AND cs.cs_net_profit > 1 
           AND cs.cs_net_paid > 0 
           AND cs.cs_quantity > 0 
           AND cs.cs_sold_date_sk = date_dim.d_date_sk 
           AND date_dim.d_year = 2001 
           AND date_dim.d_moy = 12 
         GROUP BY cs.cs_item_sk) in_cat) catalog 
   WHERE (catalog.return_rank <= 10 
          OR catalog.currency_rank <=10) 
   UNION SELECT 'store' AS channel, 
                store.item, 
                store.return_ratio, 
                store.return_rank, 
                store.currency_rank 
   FROM 
     (SELECT item, 
             return_ratio, 
             currency_ratio, 
             rank() OVER ( 
                          ORDER BY return_ratio) AS return_rank, 
                         rank() OVER ( 
                                      ORDER BY currency_ratio) AS currency_rank 
      FROM 
        (SELECT sts.ss_item_sk AS item, 
                (cast(sum(coalesce(sr.sr_return_quantity,0)) AS decimal(15,4))/cast(sum(coalesce(sts.ss_quantity,0)) AS decimal(15,4))) AS return_ratio, 
                (cast(sum(coalesce(sr.sr_return_amt,0)) AS decimal(15,4))/cast(sum(coalesce(sts.ss_net_paid,0)) AS decimal(15,4))) AS currency_ratio 
         FROM dfs.`tmp/store_sales.parquet` sts 
         LEFT OUTER JOIN dfs.`tmp/store_returns.parquet` sr ON (sts.ss_ticket_number = sr.sr_ticket_number 
                                              AND sts.ss_item_sk = sr.sr_item_sk) ,dfs.`tmp/date_dim.parquet` AS date_dim 
         WHERE sr.sr_return_amt > 10000 
           AND sts.ss_net_profit > 1 
           AND sts.ss_net_paid > 0 
           AND sts.ss_quantity > 0 
           AND sts.ss_sold_date_sk = date_dim.d_date_sk 
           AND date_dim.d_year = 2001 
           AND date_dim.d_moy = 12 
         GROUP BY sts.ss_item_sk) in_store) store 
   WHERE (store.return_rank <= 10 
          OR store.currency_rank <= 10) ) sq1 
ORDER BY 1 NULLS FIRST, 
         4 NULLS FIRST, 
         5 NULLS FIRST, 
         2 NULLS FIRST 
LIMIT 100
