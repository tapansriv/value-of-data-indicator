2025-08-20 18:36:58,798 [1759ea35-74ec-25c0-b8a3-12437628e0c3:foreman] INFO  o.a.drill.exec.work.foreman.Foreman - Query text for query with id 1759ea35-74ec-25c0-b8a3-12437628e0c3 issued by anonymous: WITH web_v1 AS 
  (SELECT web_sales.ws_item_sk item_sk, 
          date_dim.d_date, 
          sum(sum(web_sales.ws_sales_price)) OVER (PARTITION BY web_sales.ws_item_sk 
                                         ORDER BY date_dim.d_date ROWS BETWEEN unbounded preceding AND CURRENT ROW) cume_sales 
   FROM dfs.`tmp/web_sales.parquet` AS web_sales, 
        dfs.`tmp/date_dim.parquet` AS date_dim 
   WHERE web_sales.ws_sold_date_sk=date_dim.d_date_sk 
     AND date_dim.d_month_seq BETWEEN 1200 AND 1200+11 
     AND web_sales.ws_item_sk IS NOT NULL 
   GROUP BY web_sales.ws_item_sk, 
            date_dim.d_date), 
store_v1 AS 
  (SELECT store_sales.ss_item_sk item_sk, 
          date_dim.d_date, 
          sum(sum(store_sales.ss_sales_price)) OVER (PARTITION BY store_sales.ss_item_sk 
                                         ORDER BY date_dim.d_date ROWS BETWEEN unbounded preceding AND CURRENT ROW) cume_sales 
   FROM dfs.`tmp/store_sales.parquet` AS store_sales, 
        dfs.`tmp/date_dim.parquet` AS date_dim 
   WHERE store_sales.ss_sold_date_sk=date_dim.d_date_sk 
     AND date_dim.d_month_seq BETWEEN 1200 AND 1200+11 
     AND store_sales.ss_item_sk IS NOT NULL 
   GROUP BY store_sales.ss_item_sk, 
            date_dim.d_date) 
SELECT * 
FROM 
  (SELECT item_sk, 
          d_date, 
          web_sales, 
          store_sales, 
          max(web_sales) OVER (PARTITION BY item_sk 
                               ORDER BY d_date ROWS BETWEEN unbounded preceding AND CURRENT ROW) web_cumulative, 
                              max(store_sales) OVER (PARTITION BY item_sk 
                                                     ORDER BY d_date ROWS BETWEEN unbounded preceding AND CURRENT ROW) store_cumulative 
   FROM 
     (SELECT CASE 
                 WHEN web.item_sk IS NOT NULL THEN web.item_sk 
                 ELSE store.item_sk 
             END item_sk, 
             CASE 
                 WHEN web.d_date IS NOT NULL THEN web.d_date 
                 ELSE store.d_date 
             END d_date, 
             web.cume_sales web_sales, 
             store.cume_sales store_sales 
      FROM web_v1 web 
      FULL OUTER JOIN store_v1 store ON (web.item_sk = store.item_sk 
                                         AND web.d_date = store.d_date))x)y 
WHERE web_cumulative > store_cumulative 
ORDER BY item_sk NULLS FIRST, 
         d_date NULLS FIRST 
LIMIT 100
