    "query_name": "SELECT\n  *\nFROM (\n    SELECT\n      i_manager_id,\n      SUM(ss_sales_price) AS sum_sales,\n      AVG(SUM(ss_sales_price)) OVER (PARTITION BY i_manager_id) AS avg_monthly_sales\n    FROM READ_PARQUET('/home/cc/tpcds_cluster_value/item/*.parquet') AS item, READ_PARQUET('/home/cc/tpcds_cluster_value/store_sales/*.parquet') AS store_sales, READ_PARQUET('/home/cc/tpcds_cluster_base/date_dim/*.parquet') AS date_dim, READ_PARQUET('/home/cc/tpcds_cluster_base/store/*.parquet') AS store\n    WHERE\n      ss_item_sk = i_item_sk\n      AND ss_sold_date_sk = d_date_sk\n      AND ss_store_sk = s_store_sk\n      AND d_month_seq IN (\n        1200,\n        1200 + 1,\n        1200 + 2,\n        1200 + 3,\n        1200 + 4,\n        1200 + 5,\n        1200 + 6,\n        1200 + 7,\n        1200 + 8,\n        1200 + 9,\n        1200 + 10,\n        1200 + 11\n      )\n      AND (\n        (\n          i_category IN ('Books', 'Children', 'Electronics')\n          AND i_class IN ('personal', 'portable', 'reference', 'self-help')\n          AND i_brand IN (\n            'scholaramalgamalg #14',\n            'scholaramalgamalg #7',\n            'exportiunivamalg #9',\n            'scholaramalgamalg #9'\n          )\n        )\n        OR (\n          i_category IN ('Women', 'Music', 'Men')\n          AND i_class IN ('accessories', 'classical', 'fragrances', 'pants')\n          AND i_brand IN ('amalgimporto #1', 'edu packscholar #1', 'exportiimporto #1', 'importoamalg #1')\n        )\n      )\n    GROUP BY\n      i_manager_id,\n      d_moy\n) AS tmp1\nWHERE\n  CASE\n    WHEN avg_monthly_sales > 0\n    THEN ABS(sum_sales - avg_monthly_sales) / avg_monthly_sales\n    ELSE NULL\n  END > 0.1\nORDER BY\n  i_manager_id,\n  avg_monthly_sales,\n  sum_sales\nLIMIT 100",
